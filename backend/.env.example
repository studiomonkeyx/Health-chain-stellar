# Health-chain backend environment example
# Copy this file to .env and configure values before running the backend.

# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000,http://localhost:4200
TRUST_PROXY=false

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=
DATABASE_NAME=health_chain

# JWT / auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_SECRET_KID=key-1
JWT_PREVIOUS_SECRET=
JWT_PREVIOUS_SECRET_KID=key-0
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Maps
MAPS_API_KEY=your-google-maps-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Soroban Blockchain
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_SECRET_KEY=your-soroban-secret-key
SOROBAN_NETWORK=testnet
SOROBAN_CONFIRMATION_DEPTH=1
EXPECTED_CONTRACT_VERSION=1

# Per-contract addresses (populated by scripts/generate-bindings.sh after deployment).
# These take precedence over the addresses in lifebank-soroban/contracts.json.
# Leave blank to fall back to contracts.json for the active SOROBAN_NETWORK.
COORDINATOR_CONTRACT_ID=
INVENTORY_CONTRACT_ID=
PAYMENTS_CONTRACT_ID=
REQUESTS_CONTRACT_ID=
TEMPERATURE_CONTRACT_ID=

# Legacy single-contract ID (kept for backward compatibility — prefer the per-contract vars above).
SOROBAN_CONTRACT_ID=

# Blockchain callbacks
BLOCKCHAIN_CALLBACK_SECRET=your-blockchain-callback-secret
ADMIN_KEY=your-admin-key

# Africa's Talking (SMS)
AT_API_KEY=your-africastalking-api-key
AT_USERNAME=sandbox

# Firebase (Push Notifications)
FIREBASE_SERVICE_ACCOUNT_JSON=

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Account & session limits
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15
PASSWORD_HISTORY_LENGTH=3
REQUIRE_EMAIL_VERIFICATION=false
MAX_CONCURRENT_SESSIONS=5
MAX_CONCURRENT_SESSIONS_DONOR=3
MAX_CONCURRENT_SESSIONS_HOSPITAL=5
MAX_CONCURRENT_SESSIONS_ADMIN=2

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_AUTH_TTL=60
THROTTLE_AUTH_LIMIT=10
THROTTLER_USE_REDIS=true

# Inventory Forecasting
INVENTORY_FORECAST_CRON=0 */6 * * *
INVENTORY_FORECAST_THRESHOLD_DAYS=3
INVENTORY_FORECAST_HISTORY_DAYS=30

# Data Retention
RETENTION_JOB_CRON=0 2 * * *
RETENTION_SESSION_TTL_DAYS=30
RETENTION_ACTIVITY_LOG_DAYS=90

# Storage
STORAGE_PATH=./uploads
